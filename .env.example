# Configuración de Ute2MQTT
# Copia este archivo a .env y completa con tus valores

# ID de Cuenta (ejecuta setup.py para obtener tus IDs de cuenta)
UTE_ACCOUNT_ID=
UTE_SERVICE_ID=
UTE_SERVICE_POINT_ID=
UTE_TARIFF=

# Clave de encriptación para almacenamiento de tokens
# Generar con: python -c "import secrets; print(secrets.token_hex(32))"
ENCRYPTION_KEY=

# Ruta de almacenamiento de credenciales
CREDENTIALS_PATH=./credentials

# Configuración MQTT
MQTT_BROKER=localhost
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=

# Prefijo del Tópico MQTT (los sensores se publicarán en {prefix}/{account_id}/state)
MQTT_TOPIC_PREFIX=UTE
MQTT_DISCOVERY_PREFIX=homeassistant

# ID del Cliente MQTT (opcional, por defecto: ute2mqtt-{timestamp})
# Útil si tienes múltiples instancias para evitar conflictos de conexión
MQTT_CLIENT_ID=ute2mqtt

# Configuración del Horario
# AM = Ejecutar en un momento aleatorio entre 6:00-12:00
# PM = Ejecutar en un momento aleatorio entre 12:00-18:00
SCHEDULE_TIME=AM
